[commit]
    gpgSign = true

[tag]
    gpgSign = true

[core]
    editor = code --wait
    fileMode = false
    autocrlf = input
    eol = lf

[pull]
    rebase = true

[push]
    autoSetupRemote = true

[merge]
    tool = vscode
    
[mergetool "vscode"]
    cmd = code --wait $MERGED

[mergetool]
    keepBackup = false

[diff]
    tool = vscode

[difftool "vscode"]
    cmd = code --wait --diff $LOCAL $REMOTE

[safe]
    directory = *